; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="station"
run/main_scene="uid://co8y43lk7xycy"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

DevConsole="*uid://ccoijpiv8l45j"

[dev_console]

configuration/title_label="CONSOLE"
configuration/use_default_commands=true
configuration/view_default_commands=true
configuration/use_command_history=true
configuration/background_transparency=0.9
configuration/keep_size_after_closing=false
configuration/keep_position_after_closing=false
configuration/keep_topmost=true
configuration/debug_only=true

[display]

window/size/mode=3
window/size/borderless=true

[editor_plugins]

enabled=PackedStringArray("res://addons/dev-console/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"

[shader_library]

internal/previous_shaders_folder="res://shaders/shaderlib/"
